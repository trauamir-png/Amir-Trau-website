# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
# Leave empty locally if you don't need tracking during development.
NEXT_PUBLIC_GTM_ID=

# Formspree endpoint used by components/ContactForm.tsx to submit the contact form
# (e.g. https://formspree.io/f/xxxxxxxx). Get this from your form's dashboard on formspree.io.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
